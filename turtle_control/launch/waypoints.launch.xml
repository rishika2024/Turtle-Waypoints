<?xml version="1.0" encoding="UTF-8"?>
<launch>
    
 

    <!-- start a turtlesim_node in the turtlesim1 namespace -->
    <node pkg="turtlesim" exec="turtlesim_node" name="sim" namespace="turtlesim1">
       <param from="$(find-pkg-share turtle_control)/config/colors.yaml" />
    </node>

    <!-- start waypoint node -->
    
    <node pkg="turtle_control" exec="waypoint" name="waypoint_node" namespace="waypoint"> 
        <param name = "log_level" value="INFO"/>
        <param name = "frequency" value="100"/>   

    <!-- Remap topics to connect to the correct turtlesim -->
        <remap from="/turtle1/pose" to="/turtlesim1/turtle1/pose"/>
        <remap from="/turtle1/cmd_vel" to="/turtlesim1/turtle1/cmd_vel"/>    
        <remap from="reset" to="/turtlesim1/reset"/>
        <remap from="turtle1/set_pen" to="/turtlesim1/turtle1/set_pen"/>
        <remap from="turtle1/teleport_absolute" to="/turtlesim1/turtle1/teleport_absolute"/>     
        
    </node>
    

  
</launch>